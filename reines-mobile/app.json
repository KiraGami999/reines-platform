{
  "expo": {
    "name": "Reines Project Mate",
    "slug": "reines-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "reines",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d4a6b"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mw.co.reines.portal",
      "infoPlist": {
        "NSCameraUsageDescription": "Reines Project Mate uses your camera to upload project progress photos.",
        "NSPhotoLibraryUsageDescription": "Reines Project Mate accesses your photo library to upload project progress photos and payment receipts."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#2d4a6b"
      },
      "package": "mw.co.reines.portal",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Reines Project Mate accesses your photo library to upload progress photos and payment receipts.",
          "cameraPermission": "Reines Project Mate uses your camera to upload project progress photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#2d4a6b",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3d156aff-0b5a-43be-a05e-029dff2a0ca3"
      }
    }
  }
}
